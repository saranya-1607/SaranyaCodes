//TC:O(n), SC:O(1)
class Solution {
    public int maxDepth(String s) {
        int result =0;
        int curr =0;
        for(int i=0;i<s.length();i++){
            if(s.charAt(i)=='('){
                curr++;
                result =Math.max(result,curr);
            }

            if(s.charAt(i)==')'){
                curr--;
            }
        }
        return result;
    }
}
